    <!-- ==================== 视频进度条 ==================== -->
    <!-- 注意：这些尺寸专门用于视频进度条的轨道(track)部分 -->

    <!-- 进度条轨道高度 (背景条粗细) -->
    <dimen name="video_slider_track_height">4dp</dimen>
    <!-- 进度条轨道圆角半径 (高度的一半，实现半圆头效果) -->
    <dimen name="video_slider_track_radius">2dp</dimen>
    <!-- 进度条轨道内边距 (滑块手柄与轨道边缘的安全距离，防止遮挡) -->
    <dimen name="video_slider_track_padding_normal">8dp</dimen>
    <!-- 进度条滑块手柄正常尺寸直径 -->
    <dimen name="video_slider_thumb_size_normal">8dp</dimen>
    <!-- 进度条滑块手柄大尺寸直径 -->
    <dimen name="video_slider_thumb_size_big">14dp</dimen>
    <!-- 进度条滑块手柄内缩距离 (扩大触摸热区，视觉大小不变) -->
    <dimen name="video_slider_thumb_inset">12dp</dimen>


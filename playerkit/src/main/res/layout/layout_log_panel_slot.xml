<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@color/log_panel_background"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical">

    <!-- 头部：标题 + 收起/展开 -->
    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="match_parent"
        android:layout_height="@dimen/log_panel_header_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/log_panel_header_padding_horizontal"
        android:paddingTop="@dimen/log_panel_header_padding_vertical"
        android:paddingEnd="@dimen/log_panel_header_padding_horizontal"
        android:paddingBottom="@dimen/log_panel_header_padding_vertical">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/common_text_white"
            android:textSize="@dimen/log_panel_title_text_size" />

        <TextView
            android:id="@+id/tv_clear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="@dimen/log_panel_btn_padding_horizontal"
            android:paddingVertical="@dimen/log_panel_btn_padding_vertical"
            android:text="@string/log_panel_clear"
            android:textColor="@color/common_text_white"
            android:textSize="@dimen/log_panel_btn_text_size" />

        <TextView
            android:id="@+id/tv_fullscreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="@dimen/log_panel_btn_padding_horizontal"
            android:paddingVertical="@dimen/log_panel_btn_padding_vertical"
            android:text="@string/log_panel_fullscreen"
            android:textColor="@color/common_text_white"
            android:textSize="@dimen/log_panel_btn_text_size" />

    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/log_panel_divider_height"
        android:background="@color/log_panel_divider" />

    <!-- 内容区：滚动日志 -->
    <ScrollView
        android:id="@+id/sv_logs"
        android:layout_width="match_parent"
        android:layout_height="@dimen/log_panel_default_height"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tv_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/log_panel_content_padding"
            android:textColor="@color/log_panel_text_color"
            android:textSize="@dimen/log_panel_log_text_size"
            android:typeface="monospace" />
    </ScrollView>
</LinearLayout>

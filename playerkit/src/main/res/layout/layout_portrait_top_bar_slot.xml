<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/top_bar_default_height"
    android:layout_gravity="top"
    android:background="@color/common_transparent"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <!--  返回按钮  -->
    <ImageView
        android:paddingStart="@dimen/top_bar_portrait_icon_lr_margin"
        android:paddingEnd="@dimen/top_bar_icon_back_right_margin"
        android:id="@+id/iv_back"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/top_bar_icon_back_height"
        android:src="@drawable/ic_back" />

    <!--  视频标题  -->
    <TextView
        android:gravity="center_vertical"
        android:id="@+id/tv_top_bar_title"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_bar_portrait_title_height"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textStyle="normal"
        android:textColor="@color/top_bar_tv_color"
        android:shadowColor="@color/top_bar_tv_shadow"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="2"
        android:textSize="@dimen/top_bar_portrait_title_size" />

    <!--  截图按钮  -->
    <ImageView
        android:id="@+id/iv_snapshot"
        android:layout_width="@dimen/common_icon_size"
        android:layout_height="@dimen/common_icon_size"
        android:layout_marginStart="@dimen/top_bar_icon_snapshot_left_margin"
        android:layout_marginEnd="@dimen/top_bar_icon_right_margin"
        android:src="@drawable/ic_snapshot" />

    <!--  下载按钮  -->
    <!-- 当前未实现，gone 隐藏 -->
    <ImageView
        android:id="@+id/iv_download"
        android:visibility="gone"
        android:layout_width="@dimen/common_icon_size"
        android:layout_height="@dimen/common_icon_size"
        android:layout_marginEnd="@dimen/top_bar_icon_right_margin"
        android:src="@drawable/ic_download" />

    <!--  设置按钮  -->
    <ImageView
        android:id="@+id/iv_settings"
        android:layout_width="@dimen/common_icon_size"
        android:layout_height="@dimen/common_icon_size"
        android:layout_marginEnd="@dimen/top_bar_portrait_icon_lr_margin"
        android:src="@drawable/ic_settings" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- 倍速显示 - 居中顶部 -->
    <TextView
        android:id="@+id/tv_speed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="@dimen/center_display_margin_top"
        android:background="@drawable/bg_universal_slider"
        android:drawablePadding="@dimen/center_display_margin_horizontal"
        android:gravity="center"
        android:padding="@dimen/center_display_margin_vertical"
        android:textColor="@color/common_text_white"
        android:textSize="@dimen/common_text_14"
        android:textStyle="bold"
        android:visibility="gone"
        app:drawableStartCompat="@drawable/ic_speed" />

    <!-- 亮度显示 - 居中顶部 -->
    <com.aliyun.playerkit.ui.custom.UniversalSlider
        android:id="@+id/slider_brightness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="@dimen/center_display_margin_top"
        android:visibility="gone" />

    <!-- 音量显示 - 居中顶部 -->
    <com.aliyun.playerkit.ui.custom.UniversalSlider
        android:id="@+id/slider_volume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="@dimen/center_display_margin_top"
        android:visibility="gone" />

</FrameLayout>

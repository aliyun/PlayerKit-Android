<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/setting_selector_item_height"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/setting_selector_padding_horizontal"
    android:paddingEnd="@dimen/setting_selector_padding_horizontal">

    <!--  设置标题展示  -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/common_text_white"
        android:textSize="@dimen/setting_selector_text_size"
        tools:text="倍速" />

    <!--  设置值展示  -->
    <TextView
        android:id="@+id/tv_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/setting_subtitle_color"
        android:textSize="@dimen/setting_selector_text_size"
        tools:text="1.0x" />

    <!--  点击引导图标  -->
    <ImageView
        android:layout_width="@dimen/setting_selector_arrow_size"
        android:layout_height="@dimen/setting_selector_arrow_size"
        android:layout_marginStart="@dimen/setting_selector_arrow_margin"
        android:src="@drawable/ic_selector_arrow_right"
        app:tint="@color/setting_subtitle_color" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- 播放器视图（初始隐藏，选择视频源后显示） -->
    <com.aliyun.playerkit.AliPlayerView
        android:id="@+id/v_player_kit"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- 介绍区域 + 视频源选择区域（初始显示，选择后隐藏） -->
    <LinearLayout
        android:id="@+id/ll_source_selection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/video_source_example_title"
            android:textColor="@android:color/black"
            android:textSize="18dp"
            android:textStyle="bold" />

        <!-- 说明文字 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/video_source_example_description"
            android:textColor="@android:color/darker_gray"
            android:textSize="13dp" />

        <!-- 视频源选择按钮 -->
        <Button
            android:id="@+id/btn_url_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/video_source_example_btn_url_source" />

        <Button
            android:id="@+id/btn_vid_auth_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/video_source_example_btn_vid_auth_source" />

        <Button
            android:id="@+id/btn_vid_sts_source"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/video_source_example_btn_vid_sts_source" />

    </LinearLayout>

</FrameLayout>


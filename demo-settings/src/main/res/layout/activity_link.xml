<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 菜单列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/setting_item_spacing" />

    <!--  保存设置按钮  -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/setting_padding_horizontal"
        android:padding="@dimen/setting_item_padding_vertical"
        android:text="@string/setting_link_save"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="@dimen/setting_button_text_size"
        app:cornerRadius="@dimen/setting_button_corner_radius" />

</LinearLayout>
